https://{$DOMAIN} {
  encode gzip zstd

  # Enforce HTTPS for clients that have seen this host.
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  }

  # Proxy the memory API without rewriting the request path so clients
  # can sign the exact public endpoint they call.
  handle {
    reverse_proxy api:8000
  }
}
