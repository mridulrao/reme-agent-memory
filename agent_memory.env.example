# OpenAI / OpenAI-compatible
AGENT_MEMORY_OPENAI_API_KEY=sk-...
AGENT_MEMORY_LLM_MODEL=gpt-5.2
AGENT_MEMORY_EMBEDDING_MODEL=text-embedding-3-large
# Embedding vector size expected by pgvector table:
# - 3072 for text-embedding-3-large default output
# - set USE_DIMENSIONS=true and DIMENSIONS=1024 if you want compressed vectors
AGENT_MEMORY_EMBEDDING_DIMENSIONS=3072
AGENT_MEMORY_EMBEDDING_USE_DIMENSIONS=false
# Optional if using non-default endpoint
# AGENT_MEMORY_LLM_BASE_URL=https://api.openai.com/v1
# AGENT_MEMORY_EMBEDDING_BASE_URL=https://api.openai.com/v1

# Storage (required for pgvector)
AGENT_MEMORY_VECTOR_BACKEND=pgvector
AGENT_MEMORY_DB_URI=postgresql://user:password@host:5432/dbname
AGENT_MEMORY_COLLECTION_NAME=agent_memory

# Runtime
AGENT_MEMORY_WORKING_DIR=.agent_memory

# Default target for add/retrieve scripts
AGENT_MEMORY_TARGET_KIND=user
AGENT_MEMORY_TARGET_NAME=mridul
